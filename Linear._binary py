numbers = [10,25,20,30,45,50]

target = int(input("Enter Target number: "))

found = False
for i in range(len(numbers)):
    if numbers[i] == target:
        print("Element found at the index: ", i)
        found = True
        break

if not found:
    print("Element not found!")

